@*
    MapFilesComponent
    Modal body that lists all detected archive files awaiting import. While scanning
    it shows a "Scanning" indicator. When no files are present it shows "No compressed
    files found". Otherwise it renders a FileMapComponent for each detected archive,
    allowing the user to map, version, and import each file individually.
*@
@inherits FluxorComponent
@inject IState<GameArchiveImporterState> _gameArchiveImporterState

<Card>
    @if (scanning)
    {
        <div>Scanning</div>
    }
    else if (!hasData)
    {
        <div>No compressed files found</div>
    }
    else
    {
        <Repeater Items=fileMap>
            <FileMapComponent FilePath=@context.FilePath />
        </Repeater>
    }
</Card>

@code
{
    private bool scanning => _gameArchiveImporterState.Value.Scanning;
    private bool hasData => fileMap.Any();
    private List<FileMap> fileMap => _gameArchiveImporterState.Value.FileMaps;
}
