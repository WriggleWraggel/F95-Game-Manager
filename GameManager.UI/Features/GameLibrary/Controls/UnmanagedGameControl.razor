@*
    UnmanagedGameControl
    Card displayed for a locally-detected game folder that has not yet been saved to the
    library. Shows the game title and full folder path with an Add button. Clicking Add
    invokes the AddGame callback so the parent component can open the edit modal and save
    the game.
*@
<Card>
    <CardHeader>
        @Game.Title
    </CardHeader>
    <CardBody>
        @Game.FullPath
        <CardActions>
            <Button Color="Color.Primary" @onclick="@(args => AddGame.InvokeAsync(Game))">Add</Button>
        </CardActions>
    </CardBody>
</Card>

@code
{
    [Parameter, EditorRequired]
    public LocalGame Game { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<LocalGame> AddGame { get; set; }
}
